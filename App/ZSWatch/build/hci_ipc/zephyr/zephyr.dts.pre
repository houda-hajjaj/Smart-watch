&flash1 {
 reg = <0x01000000 ((256) * 1024)>;
};

&sram0 {
 reg = <0x20000000 ((512) * 1024)>;
};

&sram1 {
 reg = <0x21000000 ((64) * 1024)>;
};

/ {
 soc {
  compatible = "nordic,nrf5340-cpunet-qkaa", "nordic,nrf5340-cpunet",
        "nordic,nrf53", "simple-bus";
 };
};
